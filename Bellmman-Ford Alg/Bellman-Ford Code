from math import inf

def bellman_ford(nodes, edges, source):
    distances = {node: inf for node in nodes}  # Start distances at infinity except for source
    previous = {node: None for node in nodes}
    distances[source] = 0

    for _ in range(len(nodes) - 1):  # Relax  edges V - 1 times
        changed = False

        for u, v, weight in edges:
            if distances[u] != inf and distances[u] + weight < distances[v]:
                distances[v] = distances[u] + weight
                previous[v] = u
                changed = True

        if not changed:  # If no distance changed stop early
            break

    negative_cycle = False  # Check for a reachable negative cycle

    for u, v, weight in edges:
        if distances[u] != inf and distances[u] + weight < distances[v]:
            negative_cycle = True
            break

    return distances, previous, negative_cycle

def build_path(previous, source, target):
    path = []
    current = target

    while current is not None:
        path.append(current)

        if current == source:
            return list(reversed(path))

        current = previous[current]

    return None

def print_result(title, nodes, distances, previous, negative_cycle, source):
    print("\n" + title)
    print("-" * len(title))

    if negative_cycle:
        print("Negative cycle detected.")
        print("Shortest paths are not reliable because distances can keep decreasing.")
        return

    for node in nodes:
        distance = distances[node]

        if distance == inf:
            print(f"{node}: unreachable")
        else:
            path = build_path(previous, source, node)
            path_text = " -> ".join(path)
            print(f"{node}: distance = {distance}, path = {path_text}")



